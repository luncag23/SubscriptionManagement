@model Domain.Entities.CreativeApp
@{
    Layout = "_AdminLayout";
    var availableApps = ViewBag.AvailableApps as List<Domain.Entities.CreativeApp>;
    var currentIds = ViewBag.CurrentChildrenIds as List<Guid> ?? new List<Guid>();
}
@section Styles {
     <link rel="stylesheet" href="~/css/subscription.css" />
     <style>
          .image-preview-container {
               width: 150px;
               height: 100px;
               border: 2px dashed #ddd;
               border-radius: 12px;
               display: flex;
               align-items: center;
               justify-content: center;
               overflow: hidden;
               margin-bottom: 15px;
               background-color: #fcfcfc;
          }

          #previewImg {
               max-width: 100%;
               max-height: 100%;
               display: none;
          }
     </style>
}

<div class="sub-card" style="max-width: 700px; margin: 0 auto;">
    <span class="pattern-badge">Composite Configurator</span>
    <h2>Pachet: @Model.Name</h2>
    <hr />

    <form asp-action="EditBundle" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />

        <div class="form-section">
            <label>Nume Pachet</label>
            <input asp-for="Name" class="custom-select" required />
        </div>
          <div class="form-section">
               <label>Imagine Pachet</label>
               <div style="display: flex; align-items: center; gap: 20px; margin-bottom: 15px;">
                    <div style="width: 150px; height: 100px; border: 1px solid #ddd; border-radius: 8px; overflow: hidden; display: flex; align-items: center; justify-content: center;">
                         <img id="currentBundleImg" src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/apps/default-bundle.png" : Model.ImageUrl)"
                              style="max-width: 100%; max-height: 100%;" />
                    </div>
                    <input type="file" name="imageFile" id="editBundleImage" class="form-control" accept="image/*" />
               </div>
          </div>

        <div class="form-section">
            <label>Descriere</label>
            <textarea asp-for="Description" class="custom-select" rows="3"></textarea>
        </div>

        <div class="form-section" style="background: #f8f9fa; padding: 20px; border-radius: 12px;">
            <label class="mb-3 d-block"><b>Selectează elementele incluse în acest pachet:</b></label>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                @if (availableApps != null && availableApps.Any())
                {
                    foreach (var app in availableApps)
                    {
                        <label style="display: flex; align-items: center; gap: 10px; cursor:pointer; background:white; padding:10px; border-radius:8px; border:1px solid #ddd;">
                            @* ATENȚIE: name trebuie să fie 'selectedAppIds' *@
                            <input type="checkbox" name="selectedAppIds" value="@app.Id"
                                   @(currentIds.Contains(app.Id) ? "checked" : "")
                                   style="width:18px; height:18px;" />

                            <span>
                                @app.Name <br />
                                <small class="text-muted">@app.BasePrice.ToString("F2") RON</small>
                            </span>
                        </label>
                    }
                }
                else
                {
                    <p style="color:#999">Nu există alte aplicații în baza de date.</p>
                }
            </div>
        </div>

        <button type="submit" class="adobe-btn adobe-btn-primary w-100" style="margin-top:20px;">
            Salvează Modificările
        </button>
    </form>
</div>

@section Scripts {
     <script>
          document.getElementById('editBundleImage').onchange = function (evt) {
              const [file] = this.files;
              if (file) {
                  document.getElementById('currentBundleImg').src = URL.createObjectURL(file);
              }
          };
     </script>
}