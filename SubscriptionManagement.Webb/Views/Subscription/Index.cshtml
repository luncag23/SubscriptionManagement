@model IEnumerable<Domain.Entities.SubscriptionPlan>
@using DataContract.DTOs

@section Styles {
    <link rel="stylesheet" href="~/css/subscription.css" />
    <style>
        .checkout-container {
            max-width: 700px;
            margin: 40px auto;
        }

        .order-summary {
            background: #f8f9fa;
            padding: 25px;
            border-radius: 15px;
            border: 1px dashed #1473E6;
            margin-bottom: 25px;
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
        }

        .total-price {
            font-size: 1.6rem;
            color: #1473E6;
            font-weight: 800;
        }

        .access-option {
            border: 2px solid #eee;
            border-radius: 12px;
            padding: 18px;
            margin-bottom: 12px;
            cursor: pointer;
            transition: 0.3s;
            display: block;
            position: relative;
        }

            .access-option:hover {
                border-color: #1473E6;
                background: #f0f7ff;
            }

            .access-option input {
                margin-right: 12px;
                transform: scale(1.3);
            }

        .discount-badge {
            background: #28a745;
            color: white;
            padding: 2px 8px;
            border-radius: 10px;
            font-size: 0.75rem;
            margin-left: 10px;
        }
    </style>
}

<div class="checkout-container">
    @* --- AFIȘARE SUCCES (DESIGN MODERN) --- *@
    @if (ViewBag.Message != null)
    {
        <div class="success-card">
            <div class="success-icon">✅</div>
            <h2 style="color: #28a745; font-weight: 800;">Abonament Activat!</h2>
            <p class="success-details">
                @ViewBag.Message.Split('|')[0] <br />
                <span style="font-weight: 600; color: #1473E6;">@(ViewBag.Message.Contains("|") ? ViewBag.Message.Split('|')[1] : "")</span>
            </p>
            @if (ViewBag.LicenseKey != null)
            {
                <div class="license-box">
                    <span class="license-label">Cheia ta de activare</span>
                    <div class="license-key">@ViewBag.LicenseKey</div>
                </div>
            }
            <div style="margin-top: 25px;">
                <a href="/" class="adobe-btn adobe-btn-primary" style="width: auto; padding: 10px 30px;">Mergi la Home</a>
            </div>
        </div>
    }

    <div class="sub-card">
        <h1>Finalizare Comandă</h1>
        <p style="color:#666">Configurați accesul pentru selecția dvs.</p>
        <hr />

        @* 1. REZUMAT PRODUS (COMPOSITE) *@
        <div class="order-summary">
            <div class="summary-row">
                <span style="color:#666">Produs/Pachet:</span>
                <span style="font-weight:700">@ViewBag.SelectedProductName</span>
            </div>
            <div class="summary-row">
                <span style="color:#666">Cost lunar standard:</span>
                <span class="total-price">@ViewBag.BasePrice.ToString("F2") RON</span>
            </div>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-error"><strong>✕</strong> @ViewBag.Error</div>
        }

        <form asp-action="Subscribe" method="post">
            <input type="hidden" name="appId" value="@ViewBag.SelectedAppId" />

            @* 2. SELECȚIE DINAMICĂ PLANURI (PROTOTYPE RESULTS) *@
            <div class="form-section">
                <span class="pattern-badge">Pattern: Prototype (Dynamic)</span>
                <label class="mb-3 d-block"><b>Alege durata și tipul de acces:</b></label>

                @if (Model != null)
                {
                    foreach (var plan in Model)
                    {
                        decimal displayPrice = plan.MonthlyPrice;
                        // Dacă e un plan lunar/anual bazat pe produs, calculăm prețul relativ la BasePrice
                        if (plan.Name.ToLower().Contains("anual")) { displayPrice = ViewBag.BasePrice * 10; }
                        else if (plan.Name.ToLower().Contains("free")) { displayPrice = 0; }
                        else { displayPrice = ViewBag.BasePrice; }

                        <label class="access-option">
                            <input type="radio" name="planId" value="@plan.Id" @(plan.MonthlyPrice == 0 ? "checked" : "") required>
                            <span>
                                <b>@plan.Name</b> -
                                <span style="font-weight:700; color:var(--adobe-blue)">
                                    @(displayPrice == 0 ? "GRATUIT" : displayPrice.ToString("F2") + " RON")
                                </span>
                                @if (plan.Name.ToLower().Contains("anual"))
                                {
                                    <span class="discount-badge">2 LUNI CADOU</span>
                                }
                                <br />
                                <small class="text-muted">@plan.Description (@plan.MaxStorageGB GB Cloud Included)</small>
                            </span>
                        </label>
                    }
                }
            </div>

            @* 3. METODA DE PLATĂ (ABSTRACT FACTORY) *@
            <div class="form-section">
                <span class="pattern-badge">Pattern: Abstract Factory</span>
                <label>Metodă de Plată:</label>
                <div class="payment-grid">
                    <label class="payment-option"><input type="radio" name="paymentType" value="google" checked><span>Google Pay</span></label>
                    <label class="payment-option"><input type="radio" name="paymentType" value="paypal"><span>PayPal</span></label>
                    <label class="payment-option"><input type="radio" name="paymentType" value="card"><span>Credit Card</span></label>
                </div>
            </div>

            <button type="submit" class="btn-process" style="height: 60px; font-size: 1.2rem; margin-top: 20px;">
                Finalizează Achiziția
            </button>
        </form>
    </div>
</div>