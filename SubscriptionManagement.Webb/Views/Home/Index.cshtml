@section Styles {
    <link rel="stylesheet" href="~/css/home.css" />
}

<section class="hero-container">
    <span class="hero-tagline">Adobe Creative Cloud</span>
    <h1 class="hero-main-title">Creativitate pentru toți.</h1>
    <p class="hero-description">
        Obține acces la peste 20 de aplicații de creație, fonturi, stocare în cloud și multe altele.
        Alege planul care ți se potrivește și începe să creezi astăzi.
    </p>

    <div class="hero-actions">
        <a asp-controller="Subscription" asp-action="Index" class="btn-primary-adobe">
            Vezi planuri și prețuri
        </a>
    </div>
</section>

<section class="services-preview">
    <div class="service-item">
        <h3>Planuri pentru oricine</h3>
        <p>De la fotografi entuziaști la agenții globale, avem un abonament adaptat nevoilor tale de producție digitală.</p>
    </div>

    <div class="service-item">
        <h3>Plăți simplificate</h3>
        <p>Integrare directă cu portofele digitale și carduri bancare pentru un flux de lucru neîntrerupt și acces instant la unelte.</p>
    </div>

    <div class="service-item">
        <h3>Stocare inteligentă</h3>
        <p>Sincronizează-ți proiectele pe toate dispozitivele. Începe lucrul pe desktop și finalizează-l pe tabletă sau mobil.</p>
    </div>
</section>