@model IEnumerable<Domain.Entities.CreativeApp>
@section Styles {
    <link rel="stylesheet" href="~/css/home.css" />
}

<div class="home-wrapper">
    <!-- HERO SECTION -->
    <section class="hero-clean">
        <div class="container text-center">
            <span class="brand-tagline">Adobe Creative Cloud</span>
            <h1 class="main-headline">Creativitate pentru toți.</h1>
            <p class="sub-headline">
                Obține acces la cele mai bune unelte de creație din lume.
                Peste 20 de aplicații, stocare în cloud și resurse nelimitate.
            </p>

            <div class="cta-wrapper">
                <a asp-action="Products" class="adobe-btn-main">
                    Descoperă toate produsele
                </a>
            </div>
        </div>
    </section>

    <!-- FEATURED SECTION (DINAMIC DIN BD) -->
    <section class="featured-apps">
        <div class="container">
            <h2 class="section-title">Aplicații recomandate</h2>

            <div class="product-grid">
                @foreach (var app in Model)
                {
                    <div class="adobe-card-refined">
                        <div class="card-content">
                            <!-- IMAGINE DINAMICĂ -->
                            <div class="app-icon-wrapper" style="height: 80px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px;">
                                @if (!string.IsNullOrEmpty(app.ImageUrl))
                                {
                                    <img src="@app.ImageUrl" alt="@app.Name" style="max-height: 100%; max-width: 100%; object-fit: contain;" />
                                }
                                else
                                {
                                    <span style="font-size: 3rem;">🎨</span>
                                }
                            </div>

                            <h4 class="app-name">@app.Name</h4>

                            <!-- DESCRIERE DINAMICĂ -->
                            <p style="font-size: 0.85rem; color: #666; height: 40px; overflow: hidden; margin-bottom: 15px;">
                                @(string.IsNullOrEmpty(app.Description) ? "Descoperă puterea creativă a " + app.Name : app.Description)
                            </p>

                            <p class="app-price">@app.BasePrice.ToString("F2") RON</p>
                        </div>

                        <div class="card-footer" style="margin-top: 20px; border-top: 1px solid #f0f0f0; padding-top: 15px;">
                            <a asp-controller="Subscription" asp-action="Index" asp-route-appId="@app.Id" class="adobe-btn-link">
                                Vezi detalii & Cumpără →
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
</div>